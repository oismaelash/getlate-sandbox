// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  createdAt DateTime @default(now())

  @@index([key])
}

model Profile {
  id          Int      @id @default(autoincrement())
  getlateId   String   @unique @map("_id")
  name        String
  description String?
  createdAt   DateTime @default(now())

  socialAccounts SocialAccount[]

  @@index([getlateId])
  @@map("Profile")
}

model SocialAccount {
  id        String   @id @default(cuid())
  getlateId String   @unique @map("_id")
  profileId String
  platform  String
  username  String?
  status    String?  @default("active")
  metadata  Json?
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [getlateId], onDelete: Cascade)
  posts   Post[]

  @@index([profileId])
  @@index([getlateId])
  @@map("SocialAccount")
}

model Post {
  id              String   @id @default(cuid())
  getlateId       String   @unique @map("_id")
  socialAccountId String
  content         String?
  scheduledFor    DateTime?
  timezone        String?
  status          String   @default("scheduled")
  contentType     String?
  mediaItems      Json?
  platforms       Json?
  publishNow      Boolean  @default(false)
  createdAt       DateTime @default(now())

  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [getlateId], onDelete: Cascade)

  @@index([getlateId])
  @@index([socialAccountId])
  @@index([status])
  @@index([scheduledFor])
  @@map("Post")
}

model Webhook {
  id            String   @id @default(cuid())
  getlateId     String   @unique @map("_id")
  name          String
  url           String
  secretKey     String?
  customHeaders Json?    @default("[]")
  events        Json     // Array of event strings
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deliveryLogs WebhookDeliveryLog[]

  @@index([getlateId])
  @@index([enabled])
  @@map("Webhook")
}

model WebhookDeliveryLog {
  id            String   @id @default(cuid())
  webhookId     String
  event         String
  status        String   // "success" | "failed"
  statusCode    Int?
  responseTime  Int?     // milliseconds
  attempts      Int      @default(1)
  requestPayload Json
  response      String?  @db.Text
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [getlateId], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([timestamp])
  @@index([event])
  @@map("WebhookDeliveryLog")
}

