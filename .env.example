# Database
# Para uso local (fora do Docker): use localhost:5433
# Para uso no Docker: use db:5432 (nome do serviço)
DATABASE_URL="postgresql://getlate:getlate@db:5432/getlate_sandbox"

# Redis
# Para uso local (fora do Docker): use localhost:6380
# Para uso no Docker: use redis:6379 (nome do serviço)
REDIS_URL="redis://redis:6379"

# Next.js Environment
NODE_ENV=development

# API URL (para chamadas internas do frontend)
# No Docker, use o nome do serviço ou localhost se rodando localmente
NEXT_PUBLIC_API_URL="http://localhost:3000"

# File Watching (para hot reload no Docker/WSL2)
WATCHPACK_POLLING=true
WATCHPACK_POLLING_INTERVAL=1000
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=1000

# Next.js (desabilitar Turbopack para melhor compatibilidade com file watching)
NEXT_PRIVATE_SKIP_TURBO=1
